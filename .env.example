# Mipham Quant — 本地开发配置模板
# 使用方法: cp .env.example .env && vim .env

# Docker 镜像前缀（留空使用 Docker Hub，国内加速可用 docker.m.daocloud.io/library/）
IMAGE_PREFIX=

# 前端端口
FRONTEND_PORT=8888

# 后端端口
BACKEND_PORT=127.0.0.1:5000

# 数据库端口
DB_PORT=127.0.0.1:5432

# Redis 端口
REDIS_PORT=127.0.0.1:6379

# 时区
TZ=Asia/Shanghai

# PostgreSQL
POSTGRES_DB=mipham_quant
POSTGRES_USER=mipham
POSTGRES_PASSWORD=mipham2026
